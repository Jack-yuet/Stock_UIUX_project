{
    "version": 2,
    "builds": [
        {
            "src": "app.py",
            "use": "@vercel/python",
            "config": {
                "includeFiles": [
                    "templates/**",
                    "static/**",
                    "data/**",
                    "stock_mapping.json",
                    "services/**",
                    "routes/**",
                    "utils/**"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "app.py"
        }
    ],
    "env": {
        "VERCEL": "true",
        "NUMBA_DISABLE_JIT": "1",
        "NUMBA_CACHE_DIR": "/tmp"
    }
}